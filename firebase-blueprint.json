{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the website",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Advocate": {
      "title": "Advocate",
      "description": "Team member profiled on the advocates page",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "type": { "type": "string" },
        "focus": {
          "type": "array",
          "items": { "type": "string" }
        },
        "img": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "role", "type", "focus", "img", "createdAt", "updatedAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client success story",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "case": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "case", "text", "rating", "createdAt", "updatedAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Contact or booking inquiry",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" },
        "serviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Store admin users"
    },
    "/advocates/{advocateId}": {
      "schema": { "$ref": "#/entities/Advocate" },
      "description": "Team profiles"
    },
    "/testimonials/{testimonialId}": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Client reviews"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "Contact form submissions"
    }
  }
}
