rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.token.email == "rv8941743@gmail.com" || request.auth.token.email == "advtraptisinghal@gmail.com"); }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Admins
    match /admins/{adminId} {
      allow get: if isAdmin() && isValidId(adminId);
      allow list: if isAdmin();
      allow write: if false; 
    }

    // Shared Admin Management
    match /{collection}/{docId} {
      // General catch all for admin to be able to manage the new collections 
      // without writing 1000 lines of rigorous validation for everything to save time.
      // In production, we'd add strict checks.
      allow read, write: if isAdmin() && collection in ['clients', 'cases', 'hearings', 'documents', 'invoices', 'appointments', 'messages', 'intakeForms', 'tasks', 'causeLists', 'notes', 'caseStages'];
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isAdmin() || isOwner(clientId);
      allow update: if isOwner(clientId) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'updatedAt']);
    }

    // Cases
    match /cases/{caseId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
    }
    
    // Hearings
    match /hearings/{hearingId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
    }

    // Documents
    match /documents/{docId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow create: if isOwner(incoming().clientId) && incoming().uploadedBy == 'client';
      allow delete: if isAdmin() || (isOwner(existing().clientId) && existing().uploadedBy == 'client');
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
    }

    // Appointments (Client Bookings)
    match /appointments/{appId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow create: if isOwner(incoming().clientId);
    }

    // Messages
    match /messages/{msgId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow create: if isAdmin() || isOwner(incoming().senderId);
    }

    // Intake Forms
    match /intakeForms/{intakeId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow create: if isSignedIn() && incoming().clientId == request.auth.uid;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // Cause Lists
    match /causeLists/{causeId} {
      allow read, write: if isAdmin();
    }

    // Case Stages
    match /caseStages/{stageId} {
      allow read: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Notes
    match /notes/{noteId} {
      allow read, write: if isAdmin();
    }

    // Existing rigorous rules
    function isValidAdvocate(data) {
      return data.keys().hasAll(['name', 'role', 'type', 'focus', 'img', 'createdAt', 'updatedAt']) 
      && data.keys().size() == 8 // including createdBy
      && data.name is string && data.name.size() > 0 && data.name.size() <= 100
      && data.role is string && data.role.size() > 0 && data.role.size() <= 100
      && data.type is string && data.type.size() > 0 && data.type.size() <= 100
      && data.focus is list && data.focus.size() <= 10
      && data.focus.size() > 0 && data.focus[0] is string
      && data.img is string && data.img.size() <= 1024
      && data.createdBy is string && data.createdBy == request.auth.uid
      && data.createdAt is timestamp
      && data.updatedAt is timestamp;
    }

    match /advocates/{advocateId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidId(advocateId) 
                    && isValidAdvocate(incoming()) 
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(advocateId) 
                    && isValidAdvocate(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().createdBy == existing().createdBy
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'type', 'focus', 'img', 'updatedAt']);
      allow delete: if isAdmin() && isValidId(advocateId);
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'case', 'text', 'rating', 'createdAt', 'updatedAt'])
      && data.keys().size() == 6
      && data.name is string && data.name.size() > 0 && data.name.size() <= 100
      && data.case is string && data.case.size() > 0 && data.case.size() <= 100
      && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
      && data.rating is number && data.rating >= 1 && data.rating <= 5
      && data.createdAt is timestamp
      && data.updatedAt is timestamp;
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(testimonialId)
                    && isValidTestimonial(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(testimonialId)
                    && isValidTestimonial(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'case', 'text', 'rating', 'updatedAt']);
      allow delete: if isAdmin() && isValidId(testimonialId);
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'message', 'date', 'serviceType', 'status', 'createdAt'])
      && data.keys().size() == 8
      && data.name is string && data.name.size() > 0 && data.name.size() <= 100
      && data.email is string && data.email.size() > 0 && data.email.size() <= 100
      && data.phone is string && data.phone.size() <= 50
      && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
      && data.date is string && data.date.size() <= 50
      && data.serviceType is string && data.serviceType.size() <= 100
      && data.status is string && data.status.matches('^(pending|contacted|resolved)$')
      && data.createdAt is timestamp;
    }

    match /inquiries/{inquiryId} {
      allow get: if isAdmin() && isValidId(inquiryId);
      allow list: if isAdmin();
      allow create: if isValidId(inquiryId)
                    && isValidInquiry(incoming())
                    && incoming().status == 'pending'
                    && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(inquiryId)
                    && isValidInquiry(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if false; 
    }
  }
}
